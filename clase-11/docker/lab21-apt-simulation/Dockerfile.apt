FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    jq vim tshark net-tools && \
    rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir scapy yara-python

COPY scripts/ /app/
WORKDIR /app

# Generate APT simulation evidence
RUN python3 generate_apt_scenario.py

CMD ["/bin/bash"]
